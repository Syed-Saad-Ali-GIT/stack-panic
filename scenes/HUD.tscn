[gd_scene format=3 uid="uid://hud001"]

[sub_resource type="GDScript" id="GDScript_1"]
script/source = "
extends CanvasLayer

@onready var score_label: Label = $ScoreLabel
@onready var high_score_label: Label = $HighScoreLabel
@onready var combo_badge: Panel = $ComboBadge
@onready var combo_label: Label = $ComboBadge/ComboLabel
@onready var perfect_label: Label = $PerfectLabel
@onready var flash_overlay: ColorRect = $FlashOverlay

var flash_tween: Tween

func _ready() -> void:
	Events.score_changed.connect(_on_score_changed)
	Events.block_placed.connect(_on_block_placed)
	Events.game_started.connect(_on_game_started)
	combo_badge.visible = false
	perfect_label.visible = false
	flash_overlay.visible = false
	flash_overlay.color = Color(1, 1, 1, 0)
	high_score_label.text = 'BEST: ' + str(SaveManager.high_score)

func _on_game_started() -> void:
	score_label.text = '0'
	combo_badge.visible = false
	perfect_label.visible = false

func _on_score_changed(new_score: int) -> void:
	score_label.text = str(new_score)

func _on_block_placed(score: int, is_perfect: bool) -> void:
	if is_perfect:
		show_perfect()
		trigger_flash()

func show_perfect() -> void:
	perfect_label.visible = true
	perfect_label.modulate.a = 1.0
	var tween := create_tween()
	tween.tween_property(perfect_label, 'position:y', perfect_label.position.y - 30, 0.4)
	tween.parallel().tween_property(perfect_label, 'modulate:a', 0.0, 0.4)
	tween.tween_callback(func(): perfect_label.visible = false; perfect_label.position.y += 30)

func trigger_flash() -> void:
	flash_overlay.visible = true
	flash_overlay.color = Color(1, 1, 1, 0.6)
	if flash_tween:
		flash_tween.kill()
	flash_tween = create_tween()
	flash_tween.tween_property(flash_overlay, 'color:a', 0.0, 0.06)
	flash_tween.tween_callback(func(): flash_overlay.visible = false)

func show_combo(multiplier: int) -> void:
	combo_badge.visible = true
	combo_label.text = 'x' + str(multiplier)
	var tween := create_tween()
	tween.tween_property(combo_badge, 'scale', Vector2(1.2, 1.2), 0.1)
	tween.tween_property(combo_badge, 'scale', Vector2(1.0, 1.0), 0.1)

func hide_combo() -> void:
	combo_badge.visible = false

func update_high_score(score: int) -> void:
	high_score_label.text = 'BEST: ' + str(score)
"

[node name="HUD" type="CanvasLayer"]
script = SubResource("GDScript_1")

